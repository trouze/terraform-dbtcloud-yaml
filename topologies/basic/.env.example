# This file documents the environment variables consumed by Terraform.
#
# For local development:
#   cp .env.example .env
#   # Fill in all values in .env, then:
#   source .env && terraform plan
#
# In CI/CD, set these as secrets — never commit .env to version control:
#   GitHub Actions:  Settings > Secrets and variables > Actions
#   GitLab CI:       Settings > CI/CD > Variables (mask all of them)
#   Azure Pipelines: Library > Variable groups (mark as secret)

# ---------------------------------------------------------------
# dbt Cloud connection
# ---------------------------------------------------------------

export TF_VAR_dbt_account_id=YOUR_ACCOUNT_ID          # Numeric ID from dbt Cloud > Account Settings
export TF_VAR_dbt_token="YOUR_API_TOKEN"               # dbt Cloud service token or personal access token
export TF_VAR_dbt_host_url="https://cloud.getdbt.com/api"  # Change for single-tenant deployments

# Required for GitHub App repository integration (used to auto-discover installation IDs).
# Can be the same value as dbt_token for most setups.
export TF_VAR_dbt_pat="YOUR_API_TOKEN"

# ---------------------------------------------------------------
# Environment credentials
#
# Key format: "{project_key}_{env_key}" — must exactly match the
# key: values in dbt-config.yml.
#
# This topology uses:
#   project key: analytics
#   environment keys: prod, dev
# → credential keys: analytics_prod, analytics_dev
#
# In CI/CD, store the entire JSON blob as a single masked secret
# (e.g. DBT_ENVIRONMENT_CREDENTIALS), then export:
#   export TF_VAR_environment_credentials="$DBT_ENVIRONMENT_CREDENTIALS"
# ---------------------------------------------------------------

# ── Snowflake (key pair auth) ─────────────────────────────────────────────────
# Key format: "{project.key}_{profile.key}" — matches profiles[] in dbt-config.yml.
# Only secrets here — all other fields are in the credential: block in dbt-config.yml.
#
# private_key: PEM body with newlines replaced by \n (omit header/footer lines)
# private_key_passphrase: omit the field entirely if your key is unencrypted
export TF_VAR_environment_credentials='{
  "analytics_prod_profile": {
    "private_key": "YOUR_PRIVATE_KEY_PEM",
    "private_key_passphrase": "YOUR_PASSPHRASE"
  }
}'

# Using password auth instead? Replace credential: block in dbt-config.yml (auth_type: password)
# and supply only the password here:
# export TF_VAR_environment_credentials='{
#   "analytics_prod_profile": {
#     "password": "YOUR_PASSWORD"
#   }
# }'

# ── Databricks (replace the block above if using Databricks) ─────────────────
# export TF_VAR_environment_credentials='{
#   "analytics_prod": {
#     "credential_type": "databricks",
#     "token": "dapi_YOUR_PROD_TOKEN",
#     "catalog": "YOUR_CATALOG",
#     "schema": "YOUR_SCHEMA"
#   },
#   "analytics_dev": {
#     "credential_type": "databricks",
#     "token": "dapi_YOUR_DEV_TOKEN",
#     "catalog": "YOUR_CATALOG",
#     "schema": "YOUR_DEV_SCHEMA"
#   }
# }'

# ── BigQuery (replace the block above if using BigQuery) ─────────────────────
# export TF_VAR_environment_credentials='{
#   "analytics_prod": {
#     "credential_type": "bigquery",
#     "schema": "YOUR_PROD_DATASET",
#     "project": "YOUR_GCP_PROJECT",
#     "timeout_seconds": 300,
#     "num_threads": 8
#   },
#   "analytics_dev": {
#     "credential_type": "bigquery",
#     "schema": "YOUR_DEV_DATASET",
#     "project": "YOUR_GCP_PROJECT",
#     "timeout_seconds": 300,
#     "num_threads": 4
#   }
# }'

# ---------------------------------------------------------------
# Connection credentials
# Only needed when the global connection uses OAuth or a service
# principal. Token-based setups (Databricks PAT, Snowflake password)
# can omit this entirely — those go in environment_credentials above.
# ---------------------------------------------------------------

# export TF_VAR_connection_credentials='{
#   "main_connection": {
#     "client_id": "YOUR_CLIENT_ID",
#     "client_secret": "YOUR_CLIENT_SECRET"
#   }
# }'

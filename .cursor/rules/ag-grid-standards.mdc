## Complete Working Example

```python
from nicegui import ui
import json

def create_entity_grid(
    items: list[dict],
    on_selection_change: callable,
    pre_selected_ids: set = None
) -> ui.aggrid:
    """Create a properly configured AG Grid following all standards."""
    
    # Convert Observable types and pre-sort
    row_data = sorted(
        [dict(item) for item in items],
        key=lambda x: x.get("name", "")
    )
    pre_selected_ids = pre_selected_ids or set()
    
    # Column definitions with explicit colId
    column_defs = [
        {
            "field": "name",
            "colId": "name",
            "headerName": "Name",
            "width": 200,
            "filter": "agTextColumnFilter",
            "sortable": True,
        },
        {
            "field": "status",
            "colId": "status",
            "headerName": "Status",
            "width": 120,
            ":valueFormatter": """params => {
                const labels = {
                    'active': '✓ Active',
                    'pending': '⏳ Pending',
                    'error': '✗ Error',
                };
                return labels[params.value] || params.value;
            }""",
            "cellClassRules": {
                "status-active": "x === 'active'",
                "status-pending": "x === 'pending'",
                "status-error": "x === 'error'",
            },
        },
        {
            "field": "is_active",
            "colId": "is_active",
            "headerName": "Active",
            "width": 80,
            "cellDataType": False,  # Prevent auto-checkbox
            ":valueFormatter": "params => params.value ? '✓' : ''",
        },
    ]
    
    # Grid options
    grid_options = {
        "columnDefs": column_defs,
        "rowData": row_data,
        "rowSelection": {
            "mode": "multiRow",
            "headerCheckbox": True,
            "checkboxes": True,
        },
        "suppressRowClickSelection": True,
        "pagination": True,
        "paginationPageSize": 50,
        "paginationPageSizeSelector": [25, 50, 100],
        "rowClassRules": {
            "row-active": "data.status === 'active'",
            "row-error": "data.status === 'error'",
        },
        "defaultColDef": {
            "resizable": True,
            "sortable": True,
            "filter": True,
            "minWidth": 80,
        },
        "stopEditingWhenCellsLoseFocus": True,
        "animateRows": False,
    }
    
    # Create grid with quartz theme and auto-dark mode class
    grid = ui.aggrid(grid_options, theme="quartz").classes("w-full h-full ag-theme-quartz-auto-dark")
    
    # Pre-select rows
    if pre_selected_ids:
        all_selected = len(pre_selected_ids) == len(row_data)
        if all_selected:
            async def select_all():
                await grid.run_grid_method("selectAll")
            ui.timer(0.1, select_all, once=True)
        else:
            ids_list = list(pre_selected_ids)
            js_code = f"""
                const selectedIds = {ids_list};
                getElement({grid.id}).gridOptions.api.forEachNode(node => {{
                    if (selectedIds.includes(node.data.id)) {{
                        node.setSelected(true);
                    }}
                }});
            """
            ui.timer(0.2, lambda: ui.run_javascript(js_code), once=True)
    
    # Handle selection
    async def handle_selection():
        selected = await grid.get_selected_rows()
        on_selection_change([row["id"] for row in selected])
    
    grid.on("selectionChanged", lambda: handle_selection())
    
    # Add CSS with dark mode support
    ui.add_css("""
        .status-active { color: #059669 !important; font-weight: 600; }
        .status-pending { color: #D97706 !important; }
        .status-error { color: #DC2626 !important; font-weight: 600; }
        
        .row-active { background-color: rgba(16, 185, 129, 0.1) !important; }
        .row-error { background-color: rgba(239, 68, 68, 0.1) !important; }
        
        .dark .status-active, .body--dark .status-active { color: #6EE7B7 !important; }
        .dark .status-pending, .body--dark .status-pending { color: #FCD34D !important; }
        .dark .status-error, .body--dark .status-error { color: #FCA5A5 !important; }
        
        .dark .row-active, .body--dark .row-active {
            background-color: rgba(16, 185, 129, 0.2) !important;
        }
        .dark .row-error, .body--dark .row-error {
            background-color: rgba(239, 68, 68, 0.2) !important;
        }
    """)
    
    return grid


def create_page():
    """Example page using the grid."""
    
    with ui.element("div").style(
        "display: grid; "
        "grid-template-rows: auto 1fr; "
        "height: 100%; "
        "gap: 8px; "
        "overflow: hidden;"
    ):
        # Toolbar
        with ui.row().classes("w-full items-center gap-2"):
            search = ui.input(placeholder="Search...").props("outlined dense clearable")
            ui.button("Export CSV", icon="download")
        
        # Grid container
        with ui.element("div").classes("w-full h-full").style("min-height: 200px;"):
            grid = create_entity_grid(
                items=my_data,
                on_selection_change=handle_selection,
            )
            
            # Wire up search
            search.on("update:model-value", lambda e: grid.run_grid_method(
                'setGridOption', 'quickFilterText', e.args
            ))
```


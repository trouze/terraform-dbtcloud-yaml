## Grid Options Template

```python
# Pre-sort data in Python (no AG Grid default sort)
sorted_data = sorted(row_data, key=lambda x: x.get("name", ""))

# Convert Observable types to plain dicts
row_data = [dict(item) for item in sorted_data]

grid_options = {
    "columnDefs": column_defs,
    "rowData": row_data,
    "defaultColDef": {
        "sortable": True,
        "filter": True,
        "resizable": True,
        "flex": 1,
        "minWidth": 80,
    },
    # Row selection (read-only grids)
    "rowSelection": {"mode": "singleRow"},
    # OR for multi-select:
    # "rowSelection": {
    #     "mode": "multiRow",
    #     "headerCheckbox": True,
    #     "checkboxes": True,
    # },
    # "suppressRowClickSelection": True,  # Only checkbox selects
    "stopEditingWhenCellsLoseFocus": True,
    "animateRows": False,  # Stability
}

grid = ui.aggrid(grid_options, theme="quartz").classes("w-full h-full ag-theme-quartz-auto-dark")
```


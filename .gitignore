# Local .terraform directories
.terraform/

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data, such as
# password, private keys, and other secrets. These should not be part of version 
# control as they are data points which are potentially sensitive and subject 
# to change depending on the environment.
*.tfvars
*.tfvars.json

# Ignore override files as they are usually used to override resources locally and so
# are not checked in
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore transient lock info files created by terraform apply
.terraform.tfstate.lock.info

# Include override files you do wish to add to version control using negated pattern
# !example_override.tf

# Include tfplan files to ignore the plan output of command: terraform plan -out=tfplan
# example: *tfplan*

# Ignore CLI configuration files
.terraformrc
terraform.rc
.env

# End-to-end test outputs
test/e2e_test/dbt-cloud-config.yml
test/e2e_test/test_log.md
test/e2e_test/test_summary.md
test/e2e_test/plan_output.txt
test/e2e_test/tfplan

# Deployment directories (generated by web UI)
deployments/
terraform_output/

# Importer output files (timestamped with run IDs)
dev_support/samples/account_*_run_*__json__*.json
dev_support/samples/account_*_run_*__summary__*.md
dev_support/samples/account_*_run_*__report__*.md
dev_support/samples/account_*_run_*__report_items__*.json
dev_support/samples/account_*_run_*__logs__*.log
dev_support/samples/importer_runs.json

# Normalization output files (timestamped with normalization run IDs)
dev_support/samples/normalized/account_*_norm_*__yaml__*.yml
dev_support/samples/normalized/account_*_norm_*__lookups__*.json
dev_support/samples/normalized/account_*_norm_*__exclusions__*.md
dev_support/samples/normalized/account_*_norm_*__diff__*.json
dev_support/samples/normalized/account_*_norm_*__logs__*.log
dev_support/samples/normalized/normalization_runs.json

# Backup sample directories (created by E2E test script)
dev_support/samples.backup.*
dev_support/samples*

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
*.egg-info/
.cursor/debug.log

# Nicegui preferences
.nicegui/*
.nicegui/storage-user-e0e06ca5-55e1-475d-9cd3-b1a9e18974d6.json

# Magellan State
.magellan/*
# Ralph Wiggum state (partial)
.ralph/activity.log
.ralph/errors.log
.ralph/.iteration

# Ralph config (may contain API key)
.cursor/ralph-config.json

# Project folders (contain credentials, state, logs — defense-in-depth)
# Each project folder also has its own .gitignore as a second layer
projects/

# End-to-End Test Environment Configuration (BT profile)
#
# Copy to: test/e2e_bt/.env
# Then fill in values for your BT system.

# Source Account (for fetch)
DBT_SOURCE_HOST_URL=
DBT_SOURCE_ACCOUNT_ID=
DBT_SOURCE_API_TOKEN=

# Target Account (for Terraform apply)
# Can be same as source for testing
DBT_TARGET_ACCOUNT_ID=
DBT_TARGET_API_TOKEN=
DBT_TARGET_HOST_URL=https://cloud.getdbt.com

# Optional: PAT for GitHub App / GitLab OAuth binding and integration discovery
# DBT_TARGET_PAT=

# Optional: Scope filtering
# DBT_SCOPE=all_projects
# DBT_PROJECT_IDS=1001,1002,1003

# Optional: Terraform variables for credential secrets
# TF_VAR_databricks_token=
# TF_VAR_snowflake_password=
# TF_VAR_bigquery_service_account_json=



# Test fixture: Populated .env with real credentials
# Two environments configured with real (test) credential values
#
# Environment 1: Snowflake Production (password auth)
# Environment 2: Databricks Development

# Source dbt Cloud credentials
DBT_SOURCE_HOST_URL='https://cloud.getdbt.com'
DBT_SOURCE_ACCOUNT_ID='12345'
DBT_SOURCE_API_TOKEN='dbtc_example_token'

# Target dbt Cloud credentials
DBT_TARGET_HOST_URL='https://cloud.getdbt.com'
DBT_TARGET_ACCOUNT_ID='67890'
DBT_TARGET_API_TOKEN='dbtc_target_token'

# =============================================================================
# Environment Credentials
# =============================================================================

# Snowflake Production Environment (env_snowflake_prod)
DBT_ENV_CRED_ENV_SNOWFLAKE_PROD_USE_DUMMY='false'
DBT_ENV_CRED_ENV_SNOWFLAKE_PROD_AUTH_TYPE='password'
DBT_ENV_CRED_ENV_SNOWFLAKE_PROD_SCHEMA='ANALYTICS'
DBT_ENV_CRED_ENV_SNOWFLAKE_PROD_USER='dbt_user'
DBT_ENV_CRED_ENV_SNOWFLAKE_PROD_PASSWORD='secure_password_123'
DBT_ENV_CRED_ENV_SNOWFLAKE_PROD_NUM_THREADS='8'
DBT_ENV_CRED_ENV_SNOWFLAKE_PROD_DATABASE='PROD_DB'
DBT_ENV_CRED_ENV_SNOWFLAKE_PROD_WAREHOUSE='COMPUTE_WH'
DBT_ENV_CRED_ENV_SNOWFLAKE_PROD_ROLE='TRANSFORMER'

# Databricks Development Environment (env_databricks_dev)
DBT_ENV_CRED_ENV_DATABRICKS_DEV_USE_DUMMY='false'
DBT_ENV_CRED_ENV_DATABRICKS_DEV_TOKEN='dapiXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX'
DBT_ENV_CRED_ENV_DATABRICKS_DEV_SCHEMA='dev_analytics'
DBT_ENV_CRED_ENV_DATABRICKS_DEV_CATALOG='main'
DBT_ENV_CRED_ENV_DATABRICKS_DEV_ADAPTER_TYPE='databricks'

# Test fixture: Populated .env with dummy credentials
# Shows environments using dummy placeholder values for testing
#
# Environment 1: BigQuery Analytics (dummy)
# Environment 2: Postgres Staging (real)

# Source dbt Cloud credentials
DBT_SOURCE_HOST_URL='https://cloud.getdbt.com'
DBT_SOURCE_ACCOUNT_ID='12345'
DBT_SOURCE_API_TOKEN='dbtc_example_token'

# Target dbt Cloud credentials
DBT_TARGET_HOST_URL='https://cloud.getdbt.com'
DBT_TARGET_ACCOUNT_ID='67890'
DBT_TARGET_API_TOKEN='dbtc_target_token'

# =============================================================================
# Environment Credentials
# =============================================================================

# BigQuery Analytics Environment (env_bigquery_analytics) - DUMMY
DBT_ENV_CRED_ENV_BIGQUERY_ANALYTICS_USE_DUMMY='true'
DBT_ENV_CRED_ENV_BIGQUERY_ANALYTICS_DATASET='dummy_dataset'
DBT_ENV_CRED_ENV_BIGQUERY_ANALYTICS_NUM_THREADS='1'

# Postgres Staging Environment (env_postgres_staging) - REAL
DBT_ENV_CRED_ENV_POSTGRES_STAGING_USE_DUMMY='false'
DBT_ENV_CRED_ENV_POSTGRES_STAGING_TYPE='postgres'
DBT_ENV_CRED_ENV_POSTGRES_STAGING_USERNAME='staging_user'
DBT_ENV_CRED_ENV_POSTGRES_STAGING_PASSWORD='staging_secure_pass'
DBT_ENV_CRED_ENV_POSTGRES_STAGING_DEFAULT_SCHEMA='public'
